# CSSE4011 Kite Shell configuration

menuconfig CSSE4011_SHELL
	bool "CSSE4011 Kite Shell Commands"
	depends on SHELL
	help
	  Enable the 'kite' shell command set for the XIAO BLE board.
	  Provides board-specific commands for peripherals including
	  GPIO, ADC, I2C, UART, LED, and PWM.

if CSSE4011_SHELL

rsource "led/Kconfig"
rsource "gpio/Kconfig"
rsource "pwm/Kconfig"
rsource "uart/Kconfig"
rsource "i2c/Kconfig"
rsource "adc/Kconfig"
rsource "imu/Kconfig"
rsource "ble/Kconfig"

endif # CSSE4011_SHELL
